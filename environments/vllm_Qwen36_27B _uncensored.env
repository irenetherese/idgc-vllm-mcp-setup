PATH=$HOME/.pixi/bin:$PATH

PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
VLLM_MODEL=DavidAU/Qwen3.6-27B-Fable-Fusion-711-Uncensored-Heretic-NM-DAU-NEO-MAX-MTP-GGUF
VLLM_ARGS='
--max-model-len 188416
--safetensors-load-strategy=prefetch
--tensor-parallel-size 1
--gpu-memory-utilization 0.9115
--attention-backend flashinfer
--performance-mode interactivity
--language-model-only
--kv-cache-dtype fp8_e4m3
--trust-remote-code
--max-num-seqs 1
--max-num-batched-tokens 4096
--skip-mm-profiling
--quantization modelopt
--reasoning-parser qwen3
--no-disable-hybrid-kv-cache-manager
--enable-auto-tool-choice
--enable-chunked-prefill
--enable-prefix-caching
--tool-call-parser qwen3_coder
--quantization compressed-tensors
--speculative-config {"method":"mtp","num_speculative_tokens":3}
'

VLLM_UI_FILE=/home/dataengineer/Desktop/.vllm_env/app.py
VLLM_URL=http://172.21.0.76:5850/v1


TMPDIR=/home/dataengineer/tmp
HF_HOME=/home/dataengineer/hf_cache
TRANSFORMERS_CACHE=$HF_HOME
VLLM_CACHE_ROOT=/home/dataengineer/vllm_cache


OPENAI_API_BASE_URL=http://172.21.0.76:5850/v1


OPTIMOVE_ANALYTICS_DB_PATH=/home/dataengineer/Desktop/.local_env/Optimove/Database/players.duckdb
OPTIMOVE_ANALYTICS_METADATA=/home/dataengineer/Desktop/.vllm_env/mcp/optimove_data/metadata.json
OPTIMOVE_ANALYTICS_METRICS=/home/dataengineer/Desktop/.vllm_env/mcp/optimove_data/metrics.json

GAMING_DATA_EXPORTS_DB_PATH="/home/dataengineer/Desktop/.local_env/Backoffice Operator API Exporter/Database/exports.duckdb"