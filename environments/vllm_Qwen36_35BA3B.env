PATH=$HOME/.pixi/bin:$PATH


PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
VLLM_MODEL=/home/dataengineer/Desktop/.vllm_env/models/Qwen3.6-35B-A3B-NVFP4
VLLM_ARGS='
--max-model-len 188416
--gpu-memory-utilization 0.9115
--attention-backend flashinfer
--performance-mode interactivity
--language-model-only
--kv-cache-dtype fp8_e4m3
--trust-remote-code
--max-num-seqs 4
--max-num-batched-tokens 8192
--skip-mm-profiling
--quantization compressed-tensors
--tensor-parallel-size 1
--reasoning-parser qwen3
--enable-auto-tool-choice
--enable-prefix-caching
--tool-call-parser qwen3_coder
--disable-custom-all-reduce
'

TMPDIR=/home/dataengineer/tmp
HF_HOME=/home/dataengineer/hf_cache
TRANSFORMERS_CACHE=$HF_HOME
VLLM_CACHE_ROOT=/home/dataengineer/vllm_cache

NCCL_P2P_DISABLE=1

VLLM_USE_FLASHINFER_SAMPLER=0
VLLM_HAS_FLASHINFER_CUBIN=1
VLLM_WORKER_MULTIPROC_METHOD=fork

OPENAI_API_BASE_URL=http://172.21.0.76:5850/v1
OPTIMOVE_ANALYTICS_DB_PATH=/home/dataengineer/Desktop/.local_env/Optimove/Database/players.duckdb
OPTIMOVE_ANALYTICS_METADATA=/home/dataengineer/Desktop/.vllm_env/mcp/metadata.json
OPTIMOVE_ANALYTICS_METRICS=/home/dataengineer/Desktop/.vllm_env/mcp/metrics.json

GAMING_DATA_EXPORTS_DB_PATH="/home/dataengineer/Desktop/.local_env/Backoffice Operator API Exporter/Database/exports.duckdb"