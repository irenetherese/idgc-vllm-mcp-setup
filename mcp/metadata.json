{
  "tables": {
    "player_transactions": {
      "business_name": "Player Transactions Summary",
      "description": "Aggregated cache of player deposits and withdrawals."
    },

    "wagers": {
      "business_name": "Wager Summary",
      "description": "Aggregated wagers grouped by Product_Group, Player_ID and Date. This data already includes both sports bets and game bets."
    },

    "bets": {
      "business_name": "Sports Bet Transactions",
      "description": "Individual betting records for sports."
    },

    "bet_details": {
      "business_name": "Sports Bet Transaction Details",
      "description": "Individual bet details for each sports bet - join using Ticket_ID."
    },

    "games": {
      "business_name": "Games Transactions",
      "description": "Individual betting records for games aggregated by player, game, and date. Including games for Casino, Slots, Poker etc."
    },

    "game_types": {
      "business_name": "Game Types",
      "description": "Game descriptions"
    },

    "players": {
      "business_name": "Players",
      "description": "Player master table. Note: playerId is a unique uuid only used internally, loginId is the actual Player_ID."
    },

    "first_deposits": {
      "business_name": "First Deposits",
      "description": "Records on when the players first deposits.  DO NOT USE THIS TABLE UNLESS SPECIFICALLY INSTRUCTED."
    }
  },

  "columns": {

    "Meeting": {
      "business_name": "League",
      "description": "Competition or tournament.",
      "tables": [
        "bet_details.Meeting",
        "leagues.Meeting"
      ]
    },
    "Live": {
      "business_name": "Is Live",
      "description": "Determines whether or not he bet was made during a live match.",
      "tables": [
        "bet_details.Is_Live",
        "bets.Is_Live"
      ]
    },
    "Discipline": {
      "business_name": "Sport",
      "description": "Name of the discipline or sport.",
      "tables": [
        "bet_details.Discipline"
      ]
    },

    "Event": {
      "business_name": "Match",
      "description": "Name of the specific match or event.",
      "tables": [
        "bet_details.Event"
      ]
    },

    "createdDate": {
      "business_name": "Register Date",
      "description": "Date the player registered. Player registration date.",
      "tables": [
        "players.createdDate"
      ]
    },

    "playerId": {
      "business_name": "Player",
      "description": "Special case: playerId is a unique uuid only used internally. DO NOT USE THIS FIELD UNLESS SPECIFICALLY INSTRUCTED.",
      "tables": [
        "players.playerId"
      ]
    },

    "loginId": {
      "business_name": "Player",
      "description": "Unique player identifier. Use this field to join with Player_ID from other tables.",
      "tables": [
        "players.loginId"
      ]
    },

    "Player_ID": {
      "business_name": "Player",
      "description": "Unique player identifier.",
      "tables": [
        "transactions.Player_ID",
        "bets.Player_ID",
        "games.Player_ID",
        "player_transactions.Player_ID"
      ]
    },

    "Bet_Amount": {
      "business_name": "Wager",
      "description": "Total amount bet.",
      "tables": [
        "bets.Bet_Amount"
      ]
    },

    "Ticket_ID": {
      "business_name": "Bet Ticket",
      "description": "Bet ticket identifier.",
      "tables": [
        "bet_details.Ticket_ID",
        "bets.Ticket_ID"
      ]
    },

    "Product_Group": {
      "business_name": "Product Group",
      "description": "Category.",
      "tables": [
        "wagers.Product_Group"
      ],
      "allowed_values": [
        {"value": "Sportsbook", "description": "Sports"},
        {"value": "Casino", "description": "Casino"},
        {"value": "Slots", "description": "Slots"},
        {"value": "P2p", "description": "Poker"}
      ]
    },

    "Transaction_Type": {
      "business_name": "Transaction Type",
      "description": "Transaction Category.",
      "tables": [
        "transactions.Transaction_Type"
      ],
      "allowed_values": [
        {"value": "WITHDRAWAL", "description": "Withdrawal Transaction"},
        {"value": "DEPOSIT", "description": "Deposit Transaction"},
        {"value": "REBATE", "description": "Rebate or Bonus Transaction"}
      ]
    }
  }
}